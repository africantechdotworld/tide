<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VeltraHost — Premium VPS Hosting</title>
    <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,300;12..96,400;12..96,500;12..96,600;12..96,700;12..96,800&family=Instrument+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        * { margin:0; padding:0; box-sizing:border-box }
        :root { --blue:#1a56db; --blue-light:#eff6ff; --blue-mid:#dbeafe; --blue-dark:#1e3a8a; --blue-text:#1d4ed8; --gray:#f8fafc; --gray2:#f1f5f9; --gray3:#e2e8f0; --gray4:#94a3b8; --gray5:#64748b; --gray6:#334155; --gray7:#0f172a; --white:#ffffff; --radius:14px; --radius-sm:8px; }
        body { background:var(--white); color:var(--gray7); font-family:'Instrument Sans', sans-serif; line-height:1.6; overflow-x:hidden }
        h1, h2, h3, h4, .logo { font-family:'Bricolage Grotesque', sans-serif }
        a { text-decoration:none; color:inherit }
        nav { background:rgba(255, 255, 255, 0.95); backdrop-filter:blur(10px); border-bottom:1px solid var(--gray3); padding:0 2rem; display:flex; align-items:center; justify-content:space-between; height:68px; position:sticky; top:0; z-index:100 }
        .logo { font-size:1.45rem; font-weight:800; color:var(--gray7); letter-spacing:-0.5px }
        .logo span { color:var(--blue) }
        .nav-links { display:flex; gap:2rem; align-items:center }
        .nav-links a { font-size:0.875rem; color:var(--gray5); font-weight:500; transition:color 0.15s }
        .nav-links a:hover { color:var(--blue) }
        .nav-cta { background:var(--blue); color:var(--white); padding:0.55rem 1.4rem; border-radius:var(--radius-sm); font-size:0.875rem; font-weight:600; font-family:'Bricolage Grotesque', sans-serif; transition:background 0.15s; letter-spacing:0.01em }
        .nav-cta:hover { background:var(--blue-dark) }
        .hero { padding:6rem 2rem 5rem; text-align:center; background:var(--white); position:relative; overflow:hidden }
        .hero-bg { position:absolute; inset:0; background:radial-gradient(ellipse 80% 60% at 50% -10%, #dbeafe 0%, transparent 70%); pointer-events:none }
        .hero-content { position:relative; z-index:1; max-width:820px; margin:0 auto }
        .hero-badge { display:inline-flex; align-items:center; gap:8px; background:var(--blue-light); border:1px solid #bfdbfe; color:var(--blue-text); padding:0.4rem 1rem; border-radius:100px; font-size:0.78rem; font-weight:600; margin-bottom:1.75rem; font-family:'Bricolage Grotesque', sans-serif; letter-spacing:0.04em; text-transform:uppercase }
        .hero-badge-dot { width:7px; height:7px; background:var(--blue); border-radius:50%; animation:blink 2s infinite }
        @keyframes blink { 0%, 100% { opacity:1 } 50% { opacity:0.3 } }
        .hero h1 { font-size:clamp(2.6rem, 6vw, 4.2rem); font-weight:800; line-height:1.08; letter-spacing:-2px; color:var(--gray7); margin-bottom:1.5rem }
        .hero h1 em { font-style:normal; color:var(--blue) }
        .hero p { font-size:1.1rem; color:var(--gray5); max-width:540px; margin:0 auto 2.5rem; font-weight:400; line-height:1.7 }
        .hero-btns { display:flex; gap:0.85rem; justify-content:center; flex-wrap:wrap; margin-bottom:3.5rem }
        .btn-primary { background:var(--blue); color:var(--white); padding:0.85rem 2rem; border-radius:var(--radius-sm); font-weight:600; font-family:'Bricolage Grotesque', sans-serif; font-size:0.95rem; transition:all 0.15s; display:inline-block; letter-spacing:0.01em }
        .btn-primary:hover { background:var(--blue-dark); transform:translateY(-1px) }
        .btn-ghost { border:1.5px solid var(--gray3); color:var(--gray6); padding:0.85rem 2rem; border-radius:var(--radius-sm); font-weight:600; font-family:'Bricolage Grotesque', sans-serif; font-size:0.95rem; transition:all 0.15s; display:inline-block }
        .btn-ghost:hover { border-color:var(--blue); color:var(--blue) }
        .hero-stats { display:inline-flex; gap:0; background:var(--white); border:1px solid var(--gray3); border-radius:var(--radius); overflow:hidden }
        .stat { padding:1rem 2rem; border-right:1px solid var(--gray3); text-align:center }
        .stat:last-child { border-right:none }
        .stat-num { font-family:'Bricolage Grotesque', sans-serif; font-size:1.6rem; font-weight:800; color:var(--gray7); letter-spacing:-1px }
        .stat-label { font-size:0.75rem; color:var(--gray4); margin-top:2px; font-weight:500 }
        section { padding: 5rem 2rem }
        .container { max-width: 1100px; margin: 0 auto }
        .section-label { display:inline-block; background:var(--blue-light); color:var(--blue-text); border:1px solid #bfdbfe; padding:0.3rem 0.85rem; border-radius:100px; font-size:0.72rem; font-weight:700; margin-bottom:1rem; font-family:'Bricolage Grotesque', sans-serif; letter-spacing:0.06em; text-transform:uppercase }
        .section-title { font-size:clamp(1.9rem, 3.5vw, 2.6rem); font-weight:800; color:var(--gray7); margin-bottom:1rem; letter-spacing:-1px; line-height:1.15 }
        .features-grid { display:grid; grid-template-columns:repeat(auto-fit, minmax(300px, 1fr)); gap:1.5rem; margin-top:3rem }
        .feature-card { background:var(--white); border:1px solid var(--gray3); border-radius:var(--radius); padding:1.75rem; transition:border-color 0.15s, box-shadow 0.15s }
        .feature-card:hover { border-color:#bfdbfe; box-shadow:0 4px 20px rgba(26, 86, 219, 0.06) }
        .feature-card h3 { font-size:1rem; font-weight:700; color:var(--gray7); margin-bottom:0.5rem; font-family:'Bricolage Grotesque', sans-serif }
        .pricing-section { background:var(--gray) }
        .pricing-grid { display:grid; grid-template-columns:repeat(auto-fit, minmax(235px, 1fr)); gap:1.25rem; margin-top:3rem }
        .plan { background:var(--white); border:1.5px solid var(--gray3); border-radius:var(--radius); padding:2rem; position:relative }
        .plan-tier { font-size:0.72rem; font-weight:700; color:var(--blue); text-transform:uppercase }
        .plan-price { font-size:2rem; font-weight:800; margin-bottom:1rem }
        .plan-btn { display:block; text-align:center; padding:0.75rem; border-radius:var(--radius-sm); font-family:'Bricolage Grotesque', sans-serif; font-size:0.875rem; font-weight:700 }
        .plan-btn-outline { border:1.5px solid var(--gray3); color:var(--gray6) }
        .plan-btn-filled { background:var(--blue); color:var(--white) }
        footer { background:var(--gray7); padding:4rem 2rem 2rem; color:white }
        .footer-logo { font-family:'Bricolage Grotesque', sans-serif; font-size:1.35rem; font-weight:800; }
        .footer-logo span { color:#60a5fa }
        @media(max-width:768px) { .nav-links { display:none } }
    </style>
</head>
<body>
    <nav>
        <div class="logo">Veltra<span>Host</span></div>
        <div class="nav-links">
            <a href="#features">Features</a>
            <a href="#pricing">Pricing</a>
            <a href="{{ 'login'|link }}">Login</a>
        </div>
        <a href="{{ 'order'|link }}" class="nav-cta">Deploy Now</a>
    </nav>

    <section class="hero">
        <div class="hero-bg"></div>
        <div class="hero-content">
            <div class="hero-badge">
                <span class="hero-badge-dot"></span>
                Enterprise Cloud Infrastructure
            </div>
            <h1>The fastest VPS hosting<br>for <em>serious builders</em></h1>
            <p>Deploy your apps on NVMe SSD servers across Europe and the US.</p>
            <div class="hero-btns">
                <a href="{{ 'signup'|link }}" class="btn-primary">Get Started Now</a>
                <a href="#pricing" class="btn-ghost" style="color:#334155">See all plans</a>
            </div>
            <div class="hero-stats">
                <div class="stat">
                    <div class="stat-num">99.9%</div>
                    <div class="stat-label">Uptime SLA</div>
                </div>
                <div class="stat">
                    <div class="stat-num">&lt;20ms</div>
                    <div class="stat-label">EU Latency</div>
                </div>
                <div class="stat">
                    <div class="stat-num">NVMe</div>
                    <div class="stat-label">SSD Storage</div>
                </div>
            </div>
        </div>
    </section>

    <section id="features">
        <div class="container">
            <h2 class="section-title">Built for performance.</h2>
            <div class="features-grid">
                <div class="feature-card">
                    <h3>High-Performance Storage</h3>
                    <p>NVMe SSDs deliver exceptional speeds for your applications.</p>
                </div>
                <div class="feature-card">
                    <h3>DDoS Protection</h3>
                    <p>Every server is protected against large-scale network attacks.</p>
                </div>
            </div>
        </div>
    </section>

    <section id="pricing" class="pricing-section">
        <div class="container">
            <h2 class="section-title">Transparent pricing</h2>
            <div class="pricing-grid">
                <div class="plan">
                    <div class="plan-tier">Starter</div>
                    <div class="plan-price">$10/mo</div>
                    <a href="{{ 'order'|link }}" class="plan-btn plan-btn-outline">Select Plan</a>
                </div>
                <div class="plan featured">
                    <div class="plan-tier">Business</div>
                    <div class="plan-price">$20/mo</div>
                    <a href="{{ 'order'|link }}" class="plan-btn plan-btn-filled" style="background:#1a56db; color:white">Select Plan</a>
                </div>
            </div>
        </div>
    </section>

    <footer>
        <div class="container">
            <div class="footer-logo">Veltra<span>Host</span></div>
            <p style="margin-top:1rem; font-size:0.875rem; color:#94a3b8">© 2026 VeltraHost. All rights reserved.</p>
        </div>
    </footer>
</body>
</html>
